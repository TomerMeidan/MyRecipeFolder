# Google Cloud API key — enable "Cloud Vision API" and "Cloud Translation API"
# in your Google Cloud Console project. Starts with AIzaSy...
EXPO_PUBLIC_GOOGLE_API_KEY=your_google_cloud_api_key_here

# Google AI Studio API key — enables AI-powered recipe parsing with reasoning
# (Gemini 2.5 Flash). Get yours at aistudio.google.com. Starts with AIzaSy...
# WARNING: EXPO_PUBLIC_ keys are bundled into the app. For a production app,
# proxy this call through a backend server instead.
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here
