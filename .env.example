# Google Cloud API key — enable "Cloud Vision API" and "Cloud Translation API"
# in your Google Cloud Console project. Starts with AIzaSy...
EXPO_PUBLIC_GOOGLE_API_KEY=your_google_cloud_api_key_here

# Google AI Studio API key — enables AI-powered recipe scanning (Gemini 2.5 Flash).
# Get yours at aistudio.google.com — starts with AIzaSy...
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Supabase — cloud database and authentication.
# Get both from your Supabase project: Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
